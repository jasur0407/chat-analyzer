{
  "name": "The Syntax Syndicate",
  "type": "supergroup",
  "id": 554433221,
  "messages": [
    { "id": 1, "type": "message", "date": "2026-04-07T12:00:00", "from": "Leo", "from_id": "user_101", "text": "Is the migration finally done? I'm seeing 502 errors on the landing page." },
    { "id": 2, "type": "message", "date": "2026-04-07T12:01:05", "from": "Sarah (Dev)", "from_id": "user_102", "text": "DNS is still propagating. Give it ten minutes." },
    { "id": 3, "type": "message", "date": "2026-04-07T12:01:45", "from": "Leo", "from_id": "user_101", "text": "Ten minutes in dev-time usually means two hours." },
    { "id": 4, "type": "message", "date": "2026-04-07T12:02:10", "from": "Kevin", "from_id": "user_103", "text": "I just checked from a VPN in Germany, it's live there." },
    { "id": 5, "type": "message", "date": "2026-04-07T12:02:55", "from": "Sarah (Dev)", "from_id": "user_102", "text": "See? Trust the process, Leo." },
    { "id": 6, "type": "message", "date": "2026-04-07T12:05:00", "from": "Alex", "from_id": "user_104", "text": "By the way, did anyone see the patch notes for the new 'Neon Void' update?" },
    { "id": 7, "type": "message", "date": "2026-04-07T12:05:30", "from": "Kevin", "from_id": "user_103", "text": "The nerf to the sniper rifles is brutal. Totally unplayable now." },
    { "id": 8, "type": "message", "date": "2026-04-07T12:06:12", "from": "Leo", "from_id": "user_101", "text": "Good. You spent way too much time camping on the ridge anyway." },
    { "id": 9, "type": "message", "date": "2026-04-07T12:07:05", "from": "Alex", "from_id": "user_104", "text": "The new map layout is actually optimized for close-quarters combat now." },
    { "id": 10, "type": "message", "date": "2026-04-07T12:08:00", "from": "Sarah (Dev)", "from_id": "user_102", "text": "I'm more interested in the API changes they announced for modders." },
    { "id": 11, "type": "message", "date": "2026-04-07T12:10:00", "from": "Kevin", "from_id": "user_103", "text": "Are they finally supporting WebSockets for real-time stats?" },
    { "id": 12, "type": "message", "date": "2026-04-07T12:11:15", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Yes, but with a strict rate limit. 100 requests per minute per key." },
    { "id": 13, "type": "message", "date": "2026-04-07T12:12:40", "from": "Leo", "from_id": "user_101", "text": "That's plenty for a hobby project." },
    { "id": 14, "type": "message", "date": "2026-04-07T12:14:00", "from": "Alex", "from_id": "user_104", "text": "Should we start a private lobby tonight to test the new map?" },
    { "id": 15, "type": "message", "date": "2026-04-07T12:15:30", "from": "Kevin", "from_id": "user_103", "text": "Count me in. I need to figure out the recoil patterns." },
    { "id": 16, "type": "message", "date": "2026-04-07T12:16:10", "from": "Leo", "from_id": "user_101", "text": "I'll join after I finish debugging this CSS grid. It's driving me insane." },
    { "id": 17, "type": "message", "date": "2026-04-07T12:18:05", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Use Flexbox. It's 2026, Leo." },
    { "id": 18, "type": "message", "date": "2026-04-07T12:19:20", "from": "Leo", "from_id": "user_101", "text": "Flexbox doesn't solve this specific layout problem without messy nesting." },
    { "id": 19, "type": "message", "date": "2026-04-07T12:21:00", "from": "Alex", "from_id": "user_104", "text": "I'm getting pizza. Anyone want anything?" },
    { "id": 20, "type": "message", "date": "2026-04-07T12:22:15", "from": "Kevin", "from_id": "user_103", "text": "Pepperoni, but only if they have the thin crust." },
    { "id": 21, "type": "message", "date": "2026-04-07T12:23:45", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Just a salad for me. Working late tonight." },
    { "id": 22, "type": "message", "date": "2026-04-07T12:25:00", "from": "Leo", "from_id": "user_101", "text": "The site is up! Finally." },
    { "id": 23, "type": "message", "date": "2026-04-07T12:26:10", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Told you. Propagation is a virtue." },
    { "id": 24, "type": "message", "date": "2026-04-07T12:28:00", "from": "Kevin", "from_id": "user_103", "text": "Wait, the login button is overlapping the logo on mobile." },
    { "id": 25, "type": "message", "date": "2026-04-07T12:29:15", "from": "Leo", "from_id": "user_101", "text": "Great. That's the CSS grid I was talking about." },
    { "id": 26, "type": "message", "date": "2026-04-07T12:30:40", "from": "Sarah (Dev)", "from_id": "user_102", "text": "I'll take a look. Probably a missing media query." },
    { "id": 27, "type": "message", "date": "2026-04-07T12:32:00", "from": "Alex", "from_id": "user_104", "text": "Pizza is ordered. 30 mins." },
    { "id": 28, "type": "message", "date": "2026-04-07T12:35:00", "from": "Kevin", "from_id": "user_103", "text": "Did the client see the new landing page yet?" },
    { "id": 29, "type": "message", "date": "2026-04-07T12:36:15", "from": "Leo", "from_id": "user_101", "text": "Not yet. Hopefully they check it on desktop first." },
    { "id": 30, "type": "message", "date": "2026-04-07T12:38:00", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Mobile fix pushed to staging. Check it now." },
    { "id": 31, "type": "message", "date": "2026-04-07T12:40:20", "from": "Kevin", "from_id": "user_103", "text": "Looks perfect on my iPhone. Nice work." },
    { "id": 32, "type": "message", "date": "2026-04-07T12:42:00", "from": "Leo", "from_id": "user_101", "text": "Okay, pushing staging to production. Fingers crossed." },
    { "id": 33, "type": "message", "date": "2026-04-07T12:44:00", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Deployment successful. 0 errors in the logs." },
    { "id": 34, "type": "message", "date": "2026-04-07T12:45:10", "from": "Alex", "from_id": "user_104", "text": "Pizza is here! Let's eat and then gaming." },
    { "id": 35, "type": "message", "date": "2026-04-07T12:50:00", "from": "Kevin", "from_id": "user_103", "text": "Brb, setting up the Discord voice channel." },
    { "id": 36, "type": "message", "date": "2026-04-07T12:55:00", "from": "Leo", "from_id": "user_101", "text": "Has anyone seen the documentation for the new UI library?" },
    { "id": 37, "type": "message", "date": "2026-04-07T12:56:30", "from": "Sarah (Dev)", "from_id": "user_102", "text": "It's a bit sparse. I've been reading the source code mostly." },
    { "id": 38, "type": "message", "date": "2026-04-07T12:58:00", "from": "Leo", "from_id": "user_101", "text": "That's what I feared. Why do people hate writing docs?" },
    { "id": 39, "type": "message", "date": "2026-04-07T13:00:00", "from": "Alex", "from_id": "user_104", "text": "Because they're too busy writing more code that needs docs." },
    { "id": 40, "type": "message", "date": "2026-04-07T13:05:00", "from": "Kevin", "from_id": "user_103", "text": "The lobby is up. Password is 'syntax'." },
    { "id": 41, "type": "message", "date": "2026-04-07T13:10:00", "from": "Leo", "from_id": "user_101", "text": "Joining in 2 mins. Just closing my IDE." },
    { "id": 42, "type": "message", "date": "2026-04-07T13:15:00", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Wait, I'm getting a high latency warning on the database." },
    { "id": 43, "type": "message", "date": "2026-04-07T13:16:40", "from": "Leo", "from_id": "user_101", "text": "Again? We just upgraded the instances." },
    { "id": 44, "type": "message", "date": "2026-04-07T13:18:00", "from": "Sarah (Dev)", "from_id": "user_102", "text": "It's an unindexed query. Someone search-bar abused the system." },
    { "id": 45, "type": "message", "date": "2026-04-07T13:20:00", "from": "Leo", "from_id": "user_101", "text": "I'll fix it tomorrow morning. Let's just play for now." },
    { "id": 46, "type": "message", "date": "2026-04-07T13:22:00", "from": "Alex", "from_id": "user_104", "text": "Kevin is already in the game and he's already complaining." },
    { "id": 47, "type": "message", "date": "2026-04-07T13:23:15", "from": "Kevin", "from_id": "user_103", "text": "The lag is real! Fix the server Sarah!" },
    { "id": 48, "type": "message", "date": "2026-04-07T13:24:45", "from": "Sarah (Dev)", "from_id": "user_102", "text": "Different server, Kevin. Use your brain." },
    { "id": 49, "type": "message", "date": "2026-04-07T13:26:00", "from": "Leo", "from_id": "user_101", "text": "Savage." },
    { "id": 50, "type": "message", "date": "2026-04-07T13:30:00", "from": "Alex", "from_id": "user_104", "text": "Okay, everyone is in. Let's start." },
    { "id": 51, "type": "message", "date": "2026-04-07T14:30:00", "from": "Kevin", "from_id": "user_103", "text": "That was a great round. My sniping skills are coming back." },
    { "id": 52, "type": "message", "date": "2026-04-07T14:31:15", "from": "Leo", "from_id": "user_101", "text": "You missed like half your shots." },
    { "id": 53, "type": "message", "date": "2026-04-07T14:32:00", "from": "Sarah (Dev)", "from_id": "user_102", "text": "I'm heading to sleep. See you all at the standup tomorrow." },
    { "id": 54, "type": "message", "date": "2026-04-07T14:33:05", "from": "Alex", "from_id": "user_104", "text": "Night Sarah!" },
    { "id": 55, "type": "message", "date": "2026-04-07T14:34:00", "from": "Leo", "from_id": "user_101", "text": "Ggs everyone." }
  ]
}